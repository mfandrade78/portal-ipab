<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="style.css">
<title>Igreja Presbiteriana do Abolição</title>
</head>
<body>

<!-- logo da igreja -->
<header class="logo">
    <img src="data:image/png;base64," alt="Logo da Igreja Presbiteriana do Abolição">
        <h1>Igreja Presbiteriana<br>do Abolição</h1>
        <p>Mossoró-RN | Família da Aliança</p>
    </header>

    <!-- versículo da semana -->
    <div class="versiculo">
        <p>"Porque Deus amou o mundo de tal maneira que deu o seu Filho unigênito, para todo o que nele crê não pereça, mas tenha a vida eterna."</p>
        <span>João 3:16 - Versículo da semana</span>
    </div>

    <!-- acesso rápido -->
    <p class="section-label">Acesso rápido</p>
    <div class="grid-2>
        <a class="action-card> href="#mapa">
            <div class="icon-wrap ic-g1>📍</div>
            <div class="title">Como chegar</div>
            <div class="sub">Ver endereço</div>
        </a>
        <a class="action-card" href="#contato">
            <div class="icon-wrap ic-g2">📞</div>
            <div class="title">Contato</div>
            <div class="sub">WhatsApp · E-mail</div>
        </a> 
    </div>

    <!-- programação -->
    <p class="section-label>Programação semanal</p>
    <div class="schedule-row>
        <span class="day">Terça</span>
        <span class="name">Reunião de Oração</span>
        <span class="time">19h30 - via Google Meet</span>
    </div>
    <div class="schedule-row>
        <span class="day">Quinta</span>
        <span class="name">Reunião de Doutrina</span>
        <span class="time">19h30</span>
    </div>
    <div class="schedule-row>
        <span class="day">Domingo</span>
        <span class="name">Escola Bíblica</span>
        <span class="time">9h00</span>
    </div>
    <div class="schedule-row>
        <span class="day">Domingo</span>
        <span class="name">Culto Solene</span>
        <span class="time">18h00</span>
    </div>
</div>

<!-- redes sociais -->
<p class="section-label">Redes sociais</p>
<div class="social-row">
    <a class="social-btn s-ig" href="https://instagram.com/ipabolicao" target="_blank">📸 Instagram</a>
    <a class="social-btn s-yt" href="https://youtube.com/@IgrejaPresbiterianadoAbolição" target="_blank">▶ YouTube</a>
    <a class="social-btn s-fb" href="https://facebook.com/SUAPAGINA" target="_blank">👤 Facebook</a>
</div>

<!-- mapa -->
<p class="section-label" id="mapa">Localização</p>
<a class="map-card" href="https://maps.app.goo.gl/unHFGC5eE3q3Tww86" target="_blank">
    <div class="map-preview">🗺️</div>
    <div class="map-info">
        <div class="addr">Rua Tarcisio Correia, 1 - Abolição III, Mossoró - RN, 59600-000</div>
    </div>
</a>

<!-- galeria -->
<p class="section-label">Galeria de fotos</p>
<div class="gallery">
  <div class="gal-item">🏛️<span>Igreja</span></div>
  <div class="gal-item">🙏<span>Culto</span></div>
  <div class="gal-item">📖<span>Estudo</span></div>
  <div class="gal-item">👨‍👩‍👧<span>Membros</span></div>
  <div class="gal-item">🎵<span>Louvor</span></div>
  <div class="gal-item">➕<span>Ver mais</span></div>
</div>

<!-- contato -->
<p class="section-label" id="contato">Contato</p>
<div class="contact-card">
    <a class="contact-row" href="https://wa.me/5584933181088" target="_blank">
        <div class="contact-icon ic-g1 style="background:#e6f5eb;">💬</div>
        <div class="info">
            <div class="label">WhatsApp</div>
            <div class="value">(84) 9 3318-1088</div>
        </div>
    </a>
    <a class="contact-row" href="mailto:presbiteriana.abolicao@gmail.com">
        <div class="contact-icon ic-g2" style="background:#f0f7e0;">✉️</div>
    <div class="info">
      <div class="label">E-mail</div>
      <div class="value">contato@ipabolição.com.br</div>
    </div>
  </a>
</div>
 
<footer>
  <strong>Igreja Presbiteriana do Abolição</strong><br>
  Mossoró — RN · Por Matheus Cardoso ® Todos os direitos reservados
</footer>
 
</body>
</html>
 